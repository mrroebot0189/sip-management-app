# Work Programme Management - Environment Variables
# Copy this file to .env for local development
# In Azure App Service, set these as Application Settings

# Server
NODE_ENV=development
PORT=3001

# JWT Secret - generate a strong random string for production
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars

# Azure SQL Database Connection
# Get these from Azure Portal > SQL Database > Connection strings
DB_HOST=your-server.database.windows.net
DB_PORT=1433
DB_NAME=WorkProgrammeDB
DB_USER=your-db-admin
DB_PASSWORD=your-strong-password

# CORS - comma-separated list of allowed frontend origins
# In production: set to your Azure App Service URL
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.azurewebsites.net

# Application URL (used in email links)
APP_URL=http://localhost:3000

# Email / SMTP Configuration (for SIP submission notifications)
# Leave blank to disable email sending (projects will still be saved)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email@yourorganisation.com
SMTP_PASS=your-email-password
SMTP_FROM=sip-noreply@yourorganisation.com
